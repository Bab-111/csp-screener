# ── Data Source ───────────────────────────────────────────────────────────────
# Choose ONE provider. Free tiers work for most use cases.
#
# Option A: yfinance (default, no key needed — uses Yahoo Finance)
DATA_PROVIDER=yfinance
#
# Option B: Tradier (better options data, free sandbox available)
# DATA_PROVIDER=tradier
# TRADIER_TOKEN=your_token_here
# TRADIER_BASE_URL=https://sandbox.tradier.com/v1   # sandbox
# # TRADIER_BASE_URL=https://api.tradier.com/v1     # production
#
# Option C: Polygon.io (institutional grade, free tier = 5 calls/min)
# DATA_PROVIDER=polygon
# POLYGON_API_KEY=your_key_here

# ── Screener Parameters ────────────────────────────────────────────────────────
ACCOUNT_SIZE=50000          # Your account size in USD
MAX_POSITION_PCT=0.25       # Max single position as % of account (0.25 = 25%)
TARGET_DTE_MIN=21           # Minimum days to expiration
TARGET_DTE_MAX=45           # Maximum days to expiration
TARGET_DELTA_MAX=0.25       # Maximum absolute delta
TARGET_DELTA_MIN=0.10       # Minimum absolute delta
MIN_IVR=30                  # Minimum IV Rank
MIN_PROB_OTM=0.75           # Minimum probability OTM
MIN_ANNUAL_YIELD=0.15       # Minimum annualized yield (0.15 = 15%)
MIN_AVG_VOLUME=2000000      # Minimum average daily share volume
MIN_OI=1000                 # Minimum open interest (specific contract)
MAX_SPREAD_PCT=0.07         # Maximum bid-ask spread as % of mid
MIN_EARNINGS_DAYS=14        # Minimum days to next earnings
TOP_N=10                    # Number of candidates to return

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
SAVE_CSV=true
SAVE_JSON=true
