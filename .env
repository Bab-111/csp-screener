# ── Data Source ───────────────────────────────────────────────────────────────
DATA_PROVIDER=yfinance

# ── Screener Parameters ────────────────────────────────────────────────────────
ACCOUNT_SIZE=50000
MAX_POSITION_PCT=0.25
TARGET_DTE_MIN=21
TARGET_DTE_MAX=45
TARGET_DELTA_MAX=0.25
TARGET_DELTA_MIN=0.10
MIN_IVR=30
MIN_PROB_OTM=0.75
MIN_ANNUAL_YIELD=0.15
MIN_AVG_VOLUME=2000000
MIN_OI=200
MAX_SPREAD_PCT=0.12
MIN_EARNINGS_DAYS=14
TOP_N=10
MAX_PER_TICKER=1

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
SAVE_CSV=true
SAVE_JSON=true
SAVE_HTML=true
